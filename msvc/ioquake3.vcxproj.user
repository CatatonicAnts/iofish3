<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <LocalDebuggerCommand>E:\Games\Quake3\ioquake3.exe</LocalDebuggerCommand>
    <LocalDebuggerWorkingDirectory>E:\Games\Quake3</LocalDebuggerWorkingDirectory>
    <LocalDebuggerCommandArguments>+set cl_renderer dotnet +set vm_cgame 0 +set sv_pure 0 +set logfile 2</LocalDebuggerCommandArguments>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <LocalDebuggerCommand>E:\Games\Quake3\ioquake3.exe</LocalDebuggerCommand>
    <LocalDebuggerWorkingDirectory>E:\Games\Quake3</LocalDebuggerWorkingDirectory>
    <LocalDebuggerCommandArguments>+set cl_renderer dotnet +set vm_cgame 0 +set sv_pure 0 +set logfile 2</LocalDebuggerCommandArguments>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
</Project>
